{
  "name": "@skillpilot/openclaw",
  "version": "0.1.0",
  "description": "OpenClaw plugin adapter for SkillPilot",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skillpilot/core": "0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  },
  "peerDependencies": {
    "openclaw": "^0.x"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "skill",
    "router",
    "plugin",
    "agent"
  ],
  "author": "SkillPilot Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
