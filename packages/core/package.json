{
  "name": "@realtapel/skillpilot-core",
  "version": "0.1.0",
  "description": "Core routing engine for SkillPilot",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "better-sqlite3": "^12.0.0",
    "onnxruntime-node": "^1.20.0",
    "cosmiconfig": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent",
    "skill",
    "router",
    "llm",
    "ai",
    "embedding",
    "semantic"
  ],
  "author": "SkillPilot Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RealTapeL/SkillPilot.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
